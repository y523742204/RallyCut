{
  "name": "luffy-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint",
    "postinstall": "node -e \"const fs=require('fs');const out='public/ffmpeg';fs.mkdirSync(out,{recursive:true});fs.cpSync('node_modules/@ffmpeg/ffmpeg/dist/umd',out,{recursive:true});const core='node_modules/@ffmpeg/core/dist/umd';for(const f of ['ffmpeg-core.js','ffmpeg-core.wasm'])fs.copyFileSync(core+'/'+f,out+'/'+f)\""
  },
  "dependencies": {
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "better-sqlite3": "12.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
